{
  "title": "S3Search Observability",
  "uid": "s3search-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["s3search"],
  "templating": {
    "list": [
      {
        "name": "index",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(s3search_queries_total, index)",
        "label": "Index",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [

    { "type": "row", "id": 1, "title": "Overview", "gridPos": {"x":0,"y":0,"w":24,"h":1}, "collapsed": false },

    {
      "id": 2, "type": "stat", "title": "Query Rate",
      "gridPos": {"x":0,"y":1,"w":4,"h":4},
      "options": { "reduceOptions": {"calcs":["lastNotNull"]}, "colorMode":"background", "graphMode":"area", "textMode":"auto" },
      "fieldConfig": {
        "defaults": { "unit":"reqps", "color":{"mode":"thresholds"},
          "thresholds":{"mode":"absolute","steps":[{"color":"green","value":null},{"color":"yellow","value":10},{"color":"red","value":100}]} }
      },
      "targets": [{ "datasource":"Prometheus", "expr":"sum(rate(s3search_queries_total{index=~\"$index\"}[1m]))", "legendFormat":"queries/s" }]
    },

    {
      "id": 3, "type": "stat", "title": "P99 Query Latency",
      "gridPos": {"x":4,"y":1,"w":4,"h":4},
      "options": { "reduceOptions": {"calcs":["lastNotNull"]}, "colorMode":"background", "graphMode":"area" },
      "fieldConfig": {
        "defaults": { "unit":"s", "color":{"mode":"thresholds"},
          "thresholds":{"mode":"absolute","steps":[{"color":"green","value":null},{"color":"yellow","value":0.5},{"color":"red","value":2}]} }
      },
      "targets": [{ "datasource":"Prometheus", "expr":"histogram_quantile(0.99, sum(rate(s3search_query_duration_seconds_bucket{index=~\"$index\"}[5m])) by (le))", "legendFormat":"p99" }]
    },

    {
      "id": 4, "type": "stat", "title": "Ingest Rate",
      "gridPos": {"x":8,"y":1,"w":4,"h":4},
      "options": { "reduceOptions": {"calcs":["lastNotNull"]}, "colorMode":"background", "graphMode":"area" },
      "fieldConfig": { "defaults": { "unit":"docs/s", "color":{"mode":"thresholds"},
          "thresholds":{"mode":"absolute","steps":[{"color":"blue","value":null}]} } },
      "targets": [{ "datasource":"Prometheus", "expr":"sum(rate(s3search_ingest_docs_total{index=~\"$index\"}[1m]))", "legendFormat":"docs/s" }]
    },

    {
      "id": 5, "type": "stat", "title": "Hotcache Hit Rate",
      "gridPos": {"x":12,"y":1,"w":4,"h":4},
      "options": { "reduceOptions": {"calcs":["lastNotNull"]}, "colorMode":"background", "graphMode":"area" },
      "fieldConfig": { "defaults": { "unit":"percentunit", "min":0, "max":1,
          "color":{"mode":"thresholds"},
          "thresholds":{"mode":"absolute","steps":[{"color":"red","value":null},{"color":"yellow","value":0.7},{"color":"green","value":0.9}]} } },
      "targets": [{ "datasource":"Prometheus",
        "expr":"rate(s3search_hotcache_lookups_total{result=\"hit\"}[5m]) / (rate(s3search_hotcache_lookups_total{result=\"hit\"}[5m]) + rate(s3search_hotcache_lookups_total{result=\"miss\"}[5m]))",
        "legendFormat":"hit rate" }]
    },

    {
      "id": 6, "type": "stat", "title": "Active Segments",
      "gridPos": {"x":16,"y":1,"w":4,"h":4},
      "options": { "reduceOptions": {"calcs":["lastNotNull"]}, "colorMode":"none" },
      "fieldConfig": { "defaults": { "unit":"short" } },
      "targets": [{ "datasource":"Prometheus", "expr":"sum(s3search_active_segments{index=~\"$index\"})", "legendFormat":"segments" }]
    },

    {
      "id": 7, "type": "stat", "title": "Error Rate",
      "gridPos": {"x":20,"y":1,"w":4,"h":4},
      "options": { "reduceOptions": {"calcs":["lastNotNull"]}, "colorMode":"background" },
      "fieldConfig": { "defaults": { "unit":"reqps", "color":{"mode":"thresholds"},
          "thresholds":{"mode":"absolute","steps":[{"color":"green","value":null},{"color":"yellow","value":0.1},{"color":"red","value":1}]} } },
      "targets": [{ "datasource":"Prometheus", "expr":"sum(rate(s3search_queries_total{index=~\"$index\",status=\"error\"}[1m]))", "legendFormat":"errors/s" }]
    },

    { "type": "row", "id": 10, "title": "Query Performance", "gridPos": {"x":0,"y":5,"w":24,"h":1}, "collapsed": false },

    {
      "id": 11, "type": "timeseries", "title": "Query Rate by Status",
      "gridPos": {"x":0,"y":6,"w":12,"h":8},
      "options": { "legend":{"displayMode":"list","placement":"bottom"}, "tooltip":{"mode":"multi"} },
      "fieldConfig": { "defaults": { "unit":"reqps", "custom":{"lineWidth":2,"fillOpacity":10} } },
      "targets": [
        { "datasource":"Prometheus", "expr":"sum by(status)(rate(s3search_queries_total{index=~\"$index\"}[1m]))", "legendFormat":"{{status}}" }
      ]
    },

    {
      "id": 12, "type": "timeseries", "title": "Query Latency Percentiles",
      "gridPos": {"x":12,"y":6,"w":12,"h":8},
      "options": { "legend":{"displayMode":"list","placement":"bottom"}, "tooltip":{"mode":"multi"} },
      "fieldConfig": { "defaults": { "unit":"s", "custom":{"lineWidth":2} } },
      "targets": [
        { "datasource":"Prometheus", "expr":"histogram_quantile(0.50, sum(rate(s3search_query_duration_seconds_bucket{index=~\"$index\"}[5m])) by (le))", "legendFormat":"p50" },
        { "datasource":"Prometheus", "expr":"histogram_quantile(0.95, sum(rate(s3search_query_duration_seconds_bucket{index=~\"$index\"}[5m])) by (le))", "legendFormat":"p95" },
        { "datasource":"Prometheus", "expr":"histogram_quantile(0.99, sum(rate(s3search_query_duration_seconds_bucket{index=~\"$index\"}[5m])) by (le))", "legendFormat":"p99" }
      ]
    },

    {
      "id": 13, "type": "timeseries", "title": "Hits per Query",
      "gridPos": {"x":0,"y":14,"w":12,"h":6},
      "options": { "legend":{"displayMode":"list","placement":"bottom"} },
      "fieldConfig": { "defaults": { "unit":"short", "custom":{"lineWidth":2,"fillOpacity":5} } },
      "targets": [
        { "datasource":"Prometheus",
          "expr":"sum(rate(s3search_query_hits_total{index=~\"$index\"}[1m])) / sum(rate(s3search_queries_total{index=~\"$index\",status=\"ok\"}[1m]))",
          "legendFormat":"avg hits/query" }
      ]
    },

    {
      "id": 14, "type": "timeseries", "title": "Query Latency Heatmap (avg)",
      "gridPos": {"x":12,"y":14,"w":12,"h":6},
      "options": { "legend":{"displayMode":"list","placement":"bottom"} },
      "fieldConfig": { "defaults": { "unit":"s" } },
      "targets": [
        { "datasource":"Prometheus",
          "expr":"sum(rate(s3search_query_duration_seconds_sum{index=~\"$index\"}[1m])) / sum(rate(s3search_query_duration_seconds_count{index=~\"$index\"}[1m]))",
          "legendFormat":"avg latency" }
      ]
    },

    { "type": "row", "id": 20, "title": "Ingest Pipeline", "gridPos": {"x":0,"y":20,"w":24,"h":1}, "collapsed": false },

    {
      "id": 21, "type": "timeseries", "title": "Ingest Throughput",
      "gridPos": {"x":0,"y":21,"w":8,"h":8},
      "options": { "legend":{"displayMode":"list","placement":"bottom"} },
      "fieldConfig": { "defaults": { "unit":"docs/s", "custom":{"lineWidth":2,"fillOpacity":10} } },
      "targets": [
        { "datasource":"Prometheus", "expr":"sum by(index)(rate(s3search_ingest_docs_total{index=~\"$index\"}[1m]))", "legendFormat":"{{index}}" }
      ]
    },

    {
      "id": 22, "type": "timeseries", "title": "Flush Rate & Duration",
      "gridPos": {"x":8,"y":21,"w":8,"h":8},
      "options": { "legend":{"displayMode":"list","placement":"bottom"}, "tooltip":{"mode":"multi"} },
      "fieldConfig": { "defaults": { "unit":"s", "custom":{"lineWidth":2} } },
      "targets": [
        { "datasource":"Prometheus", "expr":"histogram_quantile(0.50, sum(rate(s3search_flush_duration_seconds_bucket{index=~\"$index\"}[5m])) by (le))", "legendFormat":"p50 flush" },
        { "datasource":"Prometheus", "expr":"histogram_quantile(0.95, sum(rate(s3search_flush_duration_seconds_bucket{index=~\"$index\"}[5m])) by (le))", "legendFormat":"p95 flush" }
      ]
    },

    {
      "id": 23, "type": "timeseries", "title": "Docs per Flush",
      "gridPos": {"x":16,"y":21,"w":8,"h":8},
      "options": { "legend":{"displayMode":"list","placement":"bottom"} },
      "fieldConfig": { "defaults": { "unit":"short", "custom":{"lineWidth":2} } },
      "targets": [
        { "datasource":"Prometheus", "expr":"histogram_quantile(0.50, sum(rate(s3search_flush_doc_count_bucket{index=~\"$index\"}[5m])) by (le))", "legendFormat":"p50 docs" },
        { "datasource":"Prometheus", "expr":"histogram_quantile(0.95, sum(rate(s3search_flush_doc_count_bucket{index=~\"$index\"}[5m])) by (le))", "legendFormat":"p95 docs" }
      ]
    },

    { "type": "row", "id": 30, "title": "Cache & Storage", "gridPos": {"x":0,"y":29,"w":24,"h":1}, "collapsed": false },

    {
      "id": 31, "type": "timeseries", "title": "Hotcache Hit / Miss Rate",
      "gridPos": {"x":0,"y":30,"w":8,"h":7},
      "options": { "legend":{"displayMode":"list","placement":"bottom"} },
      "fieldConfig": { "defaults": { "unit":"reqps", "custom":{"lineWidth":2,"fillOpacity":8} } },
      "targets": [
        { "datasource":"Prometheus", "expr":"rate(s3search_hotcache_lookups_total{result=\"hit\"}[1m])", "legendFormat":"hit" },
        { "datasource":"Prometheus", "expr":"rate(s3search_hotcache_lookups_total{result=\"miss\"}[1m])", "legendFormat":"miss" }
      ]
    },

    {
      "id": 32, "type": "gauge", "title": "Hotcache Hit Rate %",
      "gridPos": {"x":8,"y":30,"w":4,"h":7},
      "options": { "reduceOptions":{"calcs":["lastNotNull"]}, "minVizAngle":180, "maxVizAngle":180 },
      "fieldConfig": { "defaults": { "unit":"percentunit", "min":0, "max":1,
          "thresholds":{"mode":"absolute","steps":[{"color":"red","value":null},{"color":"yellow","value":0.7},{"color":"green","value":0.9}]} } },
      "targets": [{ "datasource":"Prometheus",
        "expr":"rate(s3search_hotcache_lookups_total{result=\"hit\"}[5m]) / (rate(s3search_hotcache_lookups_total{result=\"hit\"}[5m]) + rate(s3search_hotcache_lookups_total{result=\"miss\"}[5m]))",
        "legendFormat":"" }]
    },

    {
      "id": 33, "type": "timeseries", "title": "Active Segments per Index",
      "gridPos": {"x":12,"y":30,"w":12,"h":7},
      "options": { "legend":{"displayMode":"list","placement":"bottom"} },
      "fieldConfig": { "defaults": { "unit":"short", "custom":{"lineWidth":2,"fillOpacity":5} } },
      "targets": [
        { "datasource":"Prometheus", "expr":"s3search_active_segments{index=~\"$index\"}", "legendFormat":"{{index}}" }
      ]
    },

    { "type": "row", "id": 40, "title": "Compaction & Deletes", "gridPos": {"x":0,"y":37,"w":24,"h":1}, "collapsed": false },

    {
      "id": 41, "type": "timeseries", "title": "Compaction Rate",
      "gridPos": {"x":0,"y":38,"w":8,"h":7},
      "options": { "legend":{"displayMode":"list","placement":"bottom"} },
      "fieldConfig": { "defaults": { "unit":"ops/s", "custom":{"lineWidth":2} } },
      "targets": [
        { "datasource":"Prometheus", "expr":"sum by(index)(rate(s3search_compactions_total{index=~\"$index\",status=\"ok\"}[5m]))", "legendFormat":"{{index}}" }
      ]
    },

    {
      "id": 42, "type": "timeseries", "title": "Deleted Docs per Second",
      "gridPos": {"x":8,"y":38,"w":8,"h":7},
      "options": { "legend":{"displayMode":"list","placement":"bottom"} },
      "fieldConfig": { "defaults": { "unit":"docs/s", "custom":{"lineWidth":2,"fillOpacity":8} } },
      "targets": [
        { "datasource":"Prometheus", "expr":"sum by(index)(rate(s3search_deleted_docs_total{index=~\"$index\"}[1m]))", "legendFormat":"{{index}}" }
      ]
    },

    {
      "id": 43, "type": "timeseries", "title": "Merged Segments per Compaction",
      "gridPos": {"x":16,"y":38,"w":8,"h":7},
      "options": { "legend":{"displayMode":"list","placement":"bottom"} },
      "fieldConfig": { "defaults": { "unit":"short", "custom":{"lineWidth":2} } },
      "targets": [
        { "datasource":"Prometheus", "expr":"histogram_quantile(0.50, sum(rate(s3search_compaction_merged_segments_bucket{index=~\"$index\"}[5m])) by (le))", "legendFormat":"p50 segs merged" },
        { "datasource":"Prometheus", "expr":"histogram_quantile(0.95, sum(rate(s3search_compaction_merged_segments_bucket{index=~\"$index\"}[5m])) by (le))", "legendFormat":"p95 segs merged" }
      ]
    }

  ]
}
